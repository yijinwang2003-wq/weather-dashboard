# ============================================================
# Supabase credentials for the weather worker
#
# Where to find these:
#   1. Go to https://supabase.com and open your project
#   2. Click "Project Settings" (gear icon) in the left sidebar
#   3. Click "API" under the "Configuration" section
#
# SUPABASE_URL        → "Project URL" at the top of the page
# SUPABASE_SERVICE_KEY → "service_role" key under "Project API keys"
#                        (click "Reveal" to see it)
#
# WARNING: The service_role key has FULL access to your database.
#          Never commit it to git or expose it in the browser.
# ============================================================

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
